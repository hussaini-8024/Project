<UserControl x:Class="EnterpriseProcurement.Desktop.Views.Departments.DepartmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
        <TextBlock Text="Department Management" Style="{StaticResource PageTitle}" />
        <TextBlock Text="Create, edit, and deactivate organizational departments." Style="{StaticResource PageSubtitle}" />
        <DockPanel Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Content="Refresh" Style="{StaticResource GhostButton}" Command="{Binding LoadCommand}" Margin="8,0,0,0" />
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" /><ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <DataGrid Grid.Column="0" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" Margin="0,0,12,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="80" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Head" Binding="{Binding HeadName}" Width="140" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Grid.Column="1">
                <TextBlock Text="Code" Margin="0,0,0,4" /><TextBox Text="{Binding Code}" Margin="0,0,0,8" />
                <TextBlock Text="Name" Margin="0,0,0,4" /><TextBox Text="{Binding Name}" Margin="0,0,0,8" />
                <TextBlock Text="Head" Margin="0,0,0,4" /><TextBox Text="{Binding HeadName}" Margin="0,0,0,8" />
                <TextBlock Text="Description" Margin="0,0,0,4" /><TextBox Text="{Binding Description}" Margin="0,0,0,12" />
                <Button Content="Save" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" Margin="0,0,0,8" />
                <Button Content="Edit Selected" Style="{StaticResource GhostButton}" Command="{Binding EditCommand}" Margin="0,0,0,8" />
                <Button Content="Deactivate" Style="{StaticResource GhostButton}" Command="{Binding DeactivateCommand}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding Message}" Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
