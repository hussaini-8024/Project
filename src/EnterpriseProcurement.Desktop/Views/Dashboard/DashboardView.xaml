<UserControl x:Class="EnterpriseProcurement.Desktop.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
        <TextBlock Text="{Binding WelcomeTitle}" Style="{StaticResource PageTitle}" />
        <TextBlock Text="Overview of procurement, inventory, and allocation activity." Style="{StaticResource PageSubtitle}" />
        <UniformGrid Columns="4">
            <Border Style="{StaticResource StatCard}"><StackPanel>
                <TextBlock Text="Departments" Foreground="{StaticResource MutedTextBrush}" /><TextBlock Text="{Binding Stats.TotalDepartments}" FontSize="28" FontWeight="SemiBold" /></StackPanel></Border>
            <Border Style="{StaticResource StatCard}"><StackPanel>
                <TextBlock Text="Users" Foreground="{StaticResource MutedTextBrush}" /><TextBlock Text="{Binding Stats.TotalUsers}" FontSize="28" FontWeight="SemiBold" /></StackPanel></Border>
            <Border Style="{StaticResource StatCard}"><StackPanel>
                <TextBlock Text="Pending Procurement" Foreground="{StaticResource MutedTextBrush}" /><TextBlock Text="{Binding Stats.PendingProcurement}" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}" /></StackPanel></Border>
            <Border Style="{StaticResource StatCard}"><StackPanel>
                <TextBlock Text="Low Stock Alerts" Foreground="{StaticResource MutedTextBrush}" /><TextBlock Text="{Binding Stats.LowStockAlerts}" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource DangerBrush}" /></StackPanel></Border>
            <Border Style="{StaticResource StatCard}"><StackPanel>
                <TextBlock Text="Inventory Items" Foreground="{StaticResource MutedTextBrush}" /><TextBlock Text="{Binding Stats.TotalInventory}" FontSize="28" FontWeight="SemiBold" /></StackPanel></Border>
            <Border Style="{StaticResource StatCard}"><StackPanel>
                <TextBlock Text="Allocated" Foreground="{StaticResource MutedTextBrush}" /><TextBlock Text="{Binding Stats.AllocatedItems}" FontSize="28" FontWeight="SemiBold" /></StackPanel></Border>
            <Border Style="{StaticResource StatCard}"><StackPanel>
                <TextBlock Text="Returned" Foreground="{StaticResource MutedTextBrush}" /><TextBlock Text="{Binding Stats.ReturnedItems}" FontSize="28" FontWeight="SemiBold" /></StackPanel></Border>
            <Border Style="{StaticResource StatCard}"><StackPanel>
                <TextBlock Text="Approved Procurement" Foreground="{StaticResource MutedTextBrush}" /><TextBlock Text="{Binding Stats.ApprovedProcurement}" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" /></StackPanel></Border>
        </UniformGrid>
        <TextBlock Text="Recent Activity" FontWeight="SemiBold" Margin="0,8,0,8" />
        <DataGrid ItemsSource="{Binding Stats.RecentActivities}" Height="220">
            <DataGrid.Columns>
                <DataGridTextColumn Header="When" Binding="{Binding ActionAt}" Width="160" />
                <DataGridTextColumn Header="User" Binding="{Binding Username}" Width="120" />
                <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="120" />
                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="120" />
                <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
