<UserControl x:Class="EnterpriseProcurement.Desktop.Views.Reports.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
        <TextBlock Text="Reports &amp; Export" Style="{StaticResource PageTitle}" />
        <TextBlock Text="Export department, procurement, inventory, allocation, and audit reports." Style="{StaticResource PageSubtitle}" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="Procurement CSV" Style="{StaticResource PrimaryButton}" Command="{Binding ExportProcurementCommand}" Margin="0,0,8,0" />
            <Button Content="Inventory CSV" Style="{StaticResource GhostButton}" Command="{Binding ExportInventoryCommand}" Margin="0,0,8,0" />
            <Button Content="Allocations CSV" Style="{StaticResource GhostButton}" Command="{Binding ExportAllocationsCommand}" Margin="0,0,8,0" />
            <Button Content="Audit CSV" Style="{StaticResource GhostButton}" Command="{Binding ExportAuditCommand}" />
        </StackPanel>
        <Border Style="{StaticResource StatCard}" HorizontalAlignment="Left" MinWidth="480">
            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
        </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
