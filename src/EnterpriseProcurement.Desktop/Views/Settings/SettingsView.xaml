<UserControl x:Class="EnterpriseProcurement.Desktop.Views.Settings.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
        <TextBlock Text="Settings &amp; Backup" Style="{StaticResource PageTitle}" />
        <TextBlock Text="Company branding, fiscal settings, and encrypted backup/restore." Style="{StaticResource PageSubtitle}" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock Text="Organization" Margin="0,0,0,4" /><TextBox Text="{Binding OrganizationName}" Margin="0,0,0,8" />
                <TextBlock Text="Email" Margin="0,0,0,4" /><TextBox Text="{Binding Email}" Margin="0,0,0,8" />
                <TextBlock Text="Phone" Margin="0,0,0,4" /><TextBox Text="{Binding Phone}" Margin="0,0,0,8" />
                <TextBlock Text="Primary Color" Margin="0,0,0,4" /><TextBox Text="{Binding PrimaryColor}" Margin="0,0,0,12" />
                <Button Content="Save Settings" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" />
            </StackPanel>
            <StackPanel Grid.Column="1">
                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <TextBlock Text="Backup &amp; Restore" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="Backups are encrypted at rest using AES." Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,12" TextWrapping="Wrap" />
                        <Button Content="Create Backup" Style="{StaticResource PrimaryButton}" Command="{Binding BackupCommand}" Margin="0,0,0,8" />
                        <Button Content="Restore Latest Backup" Style="{StaticResource GhostButton}" Command="{Binding RestoreCommand}" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding LastBackupPath}" TextWrapping="Wrap" FontSize="11" />
                    </StackPanel>
                </Border>
                <TextBlock Text="{Binding Message}" Margin="0,12,0,0" Foreground="{StaticResource SuccessBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
