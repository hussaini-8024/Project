<UserControl x:Class="EnterpriseProcurement.Desktop.Views.Procurement.ProcurementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
        <TextBlock Text="Procurement" Style="{StaticResource PageTitle}" />
        <TextBlock Text="Purchase requests, approvals, quotations, and purchase orders." Style="{StaticResource PageSubtitle}" />
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" /><ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <DataGrid Grid.Column="0" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" Margin="0,0,12,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Number" Binding="{Binding RequestNumber}" Width="130" />
                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                    <DataGridTextColumn Header="Department" Binding="{Binding DepartmentName}" Width="120" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                    <DataGridTextColumn Header="Budget" Binding="{Binding EstimatedBudget}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Grid.Column="1">
                <TextBlock Text="Title" Margin="0,0,0,4" /><TextBox Text="{Binding Title}" Margin="0,0,0,8" />
                <TextBlock Text="Description" Margin="0,0,0,4" /><TextBox Text="{Binding Description}" Margin="0,0,0,8" />
                <TextBlock Text="Item" Margin="0,0,0,4" /><TextBox Text="{Binding ItemName}" Margin="0,0,0,8" />
                <TextBlock Text="Budget" Margin="0,0,0,4" /><TextBox Text="{Binding EstimatedBudget}" Margin="0,0,0,12" />
                <Button Content="Create Draft" Style="{StaticResource PrimaryButton}" Command="{Binding CreateDraftCommand}" Margin="0,0,0,8" />
                <Button Content="Submit" Style="{StaticResource GhostButton}" Command="{Binding SubmitCommand}" Margin="0,0,0,8" />
                <Button Content="Approve" Style="{StaticResource GhostButton}" Command="{Binding ApproveCommand}" Margin="0,0,0,8" />
                <Button Content="Reject" Style="{StaticResource GhostButton}" Command="{Binding RejectCommand}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="{StaticResource SuccessBrush}" />
            </StackPanel>
        </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
