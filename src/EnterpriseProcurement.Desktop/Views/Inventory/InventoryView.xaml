<UserControl x:Class="EnterpriseProcurement.Desktop.Views.Inventory.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
        <TextBlock Text="Inventory &amp; Assets" Style="{StaticResource PageTitle}" />
        <TextBlock Text="Manage assets, consumables, barcodes, QR codes, and stock levels." Style="{StaticResource PageSubtitle}" />
        <DockPanel Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Content="Lookup" Style="{StaticResource GhostButton}" Command="{Binding LookupBarcodeCommand}" Margin="8,0,0,0" />
            <TextBox Text="{Binding BarcodeLookup, UpdateSourceTrigger=PropertyChanged}" />
        </DockPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" /><ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <DataGrid Grid.Column="0" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" Margin="0,0,12,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Code" Binding="{Binding ItemCode}" Width="120" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantity}" Width="70" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                    <DataGridCheckBoxColumn Header="Low" Binding="{Binding IsLowStock}" Width="50" />
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Grid.Column="1">
                <TextBlock Text="Name" Margin="0,0,0,4" /><TextBox Text="{Binding Name}" Margin="0,0,0,8" />
                <TextBlock Text="Category" Margin="0,0,0,4" /><TextBox Text="{Binding Category}" Margin="0,0,0,8" />
                <TextBlock Text="Stock Qty" Margin="0,0,0,4" /><TextBox Text="{Binding StockQuantity}" Margin="0,0,0,8" />
                <TextBlock Text="Min Stock" Margin="0,0,0,4" /><TextBox Text="{Binding MinimumStock}" Margin="0,0,0,12" />
                <CheckBox Content="Low stock only" IsChecked="{Binding LowStockOnly}" Margin="0,0,0,8" />
                <Button Content="Refresh" Style="{StaticResource GhostButton}" Command="{Binding LoadCommand}" Margin="0,0,0,8" />
                <Button Content="Add Item" Style="{StaticResource PrimaryButton}" Command="{Binding CreateCommand}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="{StaticResource SuccessBrush}" />
            </StackPanel>
        </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
